APP_NAME="GM API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Africa/Abidjan

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ===== MySQL =====
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gm
DB_USERNAME=gm
DB_PASSWORD=gm

# ===== Session / Cache / Queue =====
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# ===== Redis =====
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ===== Mail (Mailpit en dev) =====
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@geniemag.ci"
MAIL_FROM_NAME="${APP_NAME}"

# ===== Stockage S3 (MinIO local) =====
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio12345
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=gm-media
AWS_ENDPOINT=http://127.0.0.1:9000
AWS_URL=http://127.0.0.1:9000/gm-media
AWS_USE_PATH_STYLE_ENDPOINT=true

# ===== MeiliSearch =====
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=masterKey

# ===== Frontend URLs (CORS) =====
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173

# ===== Intégrations externes =====
# Paystack (gateway de paiement principal)
# - Récupérez les clés sur https://dashboard.paystack.com/#/settings/developers
# - En dev, laissez `sk_test_placeholder` pour activer le simulateur local.
# - Après login Paystack, configurez le webhook URL :
#     https://votre-domaine.tld/webhooks/paystack (POST)
# - Devises supportées en CI : XOF (compte Paystack CI requis).
PAYMENT_GATEWAY=paystack
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxx
PAYSTACK_BASE_URL=https://api.paystack.co
# Liste officielle des IPs sortantes Paystack (mise à jour par Paystack) :
# https://paystack.com/docs/payments/webhooks/#ip-whitelisting
# Laissez VIDE pour désactiver la whitelist IP (dev/ngrok).
PAYSTACK_WEBHOOK_IPS=52.31.139.75,52.49.173.169,52.214.14.220

SENDGRID_API_KEY=
MAILJET_API_KEY=
MAILJET_API_SECRET=

SENTRY_LARAVEL_DSN=
