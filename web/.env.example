APP_NAME="GM API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Africa/Abidjan

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ===== MySQL =====
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gm
DB_USERNAME=gm
DB_PASSWORD=changeme-dev-only

# ===== Session / Cache / Queue =====
# EN PROD : SESSION_SECURE_COOKIE=true, SESSION_SAME_SITE=lax (ou strict si
# pas de flux OAuth tiers), SESSION_ENCRYPT=true pour chiffrer le payload
# session en base (défense en profondeur si la DB fuit).
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SESSION_HTTP_ONLY=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# ===== Redis =====
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ===== Mail (Mailpit en dev) =====
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@geniemag.ci"
MAIL_FROM_NAME="${APP_NAME}"

# ===== Stockage S3 (MinIO local) =====
AWS_ACCESS_KEY_ID=changeme-dev-only
AWS_SECRET_ACCESS_KEY=changeme-dev-only
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=gm-media
AWS_ENDPOINT=http://127.0.0.1:9000
AWS_URL=http://127.0.0.1:9000/gm-media
AWS_USE_PATH_STYLE_ENDPOINT=true

# ===== MeiliSearch =====
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=changeme-dev-only

# ===== Frontend URLs (CORS) =====
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173

# ===== Reverse proxy / Cloudflare =====
# Obligatoire en prod derrière Cloudflare, Nginx, ALB : sans cette variable,
# request()->ip() renvoie l'IP du proxy (constante) et toute défense IP-based
# s'effondre (whitelist webhook Paystack, throttles, freemium counter, audit).
# Valeurs possibles :
#   *           → tous les proxies sont de confiance (simple mais moins sûr)
#   10.0.0.0/8  → CIDR (plage privée)
#   1.2.3.4,5.6.7.8 → liste explicite d'IPs (séparées par virgule)
TRUSTED_PROXIES=

# ===== Intégrations externes =====
# Gateway de paiement : `wave` (défaut) ou `paystack`. Mettre `fake` pour
# forcer le simulateur local quel que soit l'environnement.
PAYMENT_GATEWAY=wave

# ----- Wave Business (gateway principal, Côte d'Ivoire) -----
# 1. Créer un compte marchand sur https://business.wave.com
# 2. Générer une clé API sur https://business.wave.com/dev-portal
# 3. En DEV, laissez `wave_test_placeholder` pour activer le simulateur local.
# 4. Configurer le webhook sur le dashboard Wave :
#      URL   : https://votre-domaine.tld/webhooks/wave (POST)
#      Événements : checkout.session.completed, checkout.session.payment_failed
#    Wave vous fournira un webhook secret à coller dans WAVE_WEBHOOK_SECRET.
# 5. Devises : XOF (Côte d'Ivoire, Sénégal, UEMOA).
WAVE_API_KEY=wave_test_placeholder
WAVE_WEBHOOK_SECRET=wave_webhook_placeholder
WAVE_BASE_URL=https://api.wave.com
# Optionnel : whitelist IP du webhook Wave (Wave ne publie pas de liste
# officielle stable — demander à votre contact Wave). Vide = désactivé.
WAVE_WEBHOOK_IPS=

# ----- Paystack (provider secondaire optionnel) -----
# Utilisé uniquement si PAYMENT_GATEWAY=paystack. Récupérer les clés sur
# https://dashboard.paystack.com/#/settings/developers. Webhook :
#   https://votre-domaine.tld/webhooks/paystack (POST)
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_placeholder
PAYSTACK_BASE_URL=https://api.paystack.co
# Liste officielle : https://paystack.com/docs/payments/webhooks/#ip-whitelisting
PAYSTACK_WEBHOOK_IPS=52.31.139.75,52.49.173.169,52.214.14.220

SENDGRID_API_KEY=
MAILJET_API_KEY=
MAILJET_API_SECRET=

SENTRY_LARAVEL_DSN=
