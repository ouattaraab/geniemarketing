# ==============================================================================
# GÉNIE MARKETING Mag — .env production (Hostinger Mutualisé)
# ------------------------------------------------------------------------------
# À copier en `geniemag-app/.env` sur le serveur et compléter avec les vrais
# secrets. NE JAMAIS commiter ce fichier rempli.
#
# Contraintes mutualisé :
#   - Pas de Redis → queue/cache/session en BDD
#   - Pas de Meilisearch → scout en collection (in-memory) ou database
#   - Pas de Docker, pas de Supervisor → queue via cron
#   - Storage local dans storage/app/public (symlink public_html/storage)
# ==============================================================================

APP_NAME="GÉNIE MARKETING Mag"
APP_ENV=production
APP_KEY=                                # ← php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://geniemag.ci
APP_TIMEZONE=Africa/Abidjan
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ===== Logs =====
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning
LOG_DAILY_DAYS=14
LOG_DEPRECATIONS_CHANNEL=null

# ===== MySQL (provisionné via hPanel → Databases → MySQL Databases) =====
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=uXXXXXXXXX_geniemag
DB_USERNAME=uXXXXXXXXX_geniemag
DB_PASSWORD=                            # ← mot de passe fort 32+ caractères

# ===== Session / Cache / Queue (tout en BDD sur mutualisé) =====
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.geniemag.ci
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_HTTP_ONLY=true

CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log

# ===== Stockage local (pas d'S3/MinIO sur mutualisé) =====
FILESYSTEM_DISK=public                  # storage/app/public via symlink

# ===== Scout : moteur recherche léger =====
# `collection` = in-memory, OK jusqu'à ~1000 articles (réindexé à chaque requête).
# `database`   = utilise MATCH AGAINST FULLTEXT MySQL, scale mieux mais nécessite
#                un index FULLTEXT sur les colonnes searchables.
SCOUT_DRIVER=collection

# ===== Mail — SMTP Hostinger (inclus dans le plan) =====
# Créer la boîte via hPanel → Emails puis renseigner ici.
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=no-reply@geniemag.ci
MAIL_PASSWORD=                          # ← mdp de la boîte email
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="no-reply@geniemag.ci"
MAIL_FROM_NAME="${APP_NAME}"

# ===== Reverse proxy =====
# Hostinger place un LB/LiteSpeed devant Apache. Les vraies IPs arrivent via
# X-Forwarded-For.
#
# ⚠ SÉCURITÉ : `TRUSTED_PROXIES=*` rend l'IP cliente librement falsifiable par
# n'importe quel requêteur (envoi d'un X-Forwarded-For arbitraire). Conséquences :
#   - La whitelist webhook Wave devient contournable.
#   - Les preuves de consentement RGPD (table `consents`, colonne `ip`)
#     perdent leur valeur probatoire devant un juge.
#   - Les freemium counters et throttles IP-based deviennent inopérants.
#
# Recommandation forte : placer Cloudflare devant le site et configurer ici
# la liste officielle des subnets Cloudflare :
#   https://www.cloudflare.com/ips-v4/
# Exemple :
#   TRUSTED_PROXIES=173.245.48.0/20,103.21.244.0/22,103.22.200.0/22,103.31.4.0/22,...
#
# Si aucun proxy n'est connu (DEV local) : laisser vide (valeur par défaut
# Laravel = pas de trust, `request()->ip()` = IP observée).
#
# À défaut (dev Hostinger sans CF), `*` reste possible mais les preuves
# Consent perdent leur valeur juridique.
TRUSTED_PROXIES=

# ===== Wave Business (gateway principal — production) =====
# 1. Compte marchand : https://business.wave.com
# 2. Clé API production : https://business.wave.com/dev-portal
#    (clé format `wave_ci_prod_...` ou `wave_sn_prod_...`)
# 3. Webhook dashboard Wave → URL : https://geniemag.ci/webhooks/wave
#    Événements : checkout.session.completed, checkout.session.payment_failed
#    Wave vous fournit un webhook secret (format `whsec_...`) à coller dans
#    WAVE_WEBHOOK_SECRET ci-dessous.
PAYMENT_GATEWAY=wave
WAVE_API_KEY=                           # ← clé production Wave (jamais commiter)
WAVE_WEBHOOK_SECRET=                    # ← secret webhook fourni par Wave
WAVE_BASE_URL=https://api.wave.com
# Optionnel : whitelist IP sortantes Wave si fournie par votre contact.
WAVE_WEBHOOK_IPS=

# ===== Paystack (fallback optionnel, désactivé par défaut) =====
# Décommenter et mettre PAYMENT_GATEWAY=paystack pour basculer si besoin.
# PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxx
# PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxx
# PAYSTACK_BASE_URL=https://api.paystack.co
# PAYSTACK_WEBHOOK_IPS=52.31.139.75,52.49.173.169,52.214.14.220

# ===== Sentry (fortement recommandé — remonte les Log::critical) =====
SENTRY_LARAVEL_DSN=

# ===== Front URLs =====
FRONTEND_URL=https://geniemag.ci
ADMIN_URL=https://geniemag.ci
