# Environnement Docker local — copier en .env et ajuster

# MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=gm
MYSQL_USER=gm
MYSQL_PASSWORD=gm
MYSQL_PORT=3306

# Redis
REDIS_PORT=6379

# MinIO (S3-compatible)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio12345
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Mailpit (SMTP local)
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# MeiliSearch
MEILI_MASTER_KEY=masterKey
MEILI_PORT=7700
